{
  "manifest_version": 3,
  "name": "Scrapify",
  "short_name": "Scrapify",
  "version": "1.0.0",
  "description": "Scrapify scrapes Google Maps listings with filters and CSV export.",
  "icons": {
    "16": "assets/brand/icon-16.png",
    "32": "assets/brand/icon-32.png",
    "48": "assets/brand/icon-48.png",
    "128": "assets/brand/icon-128.png"
  },
  "permissions": ["activeTab", "tabs", "storage", "downloads", "scripting", "unlimitedStorage"],
  "host_permissions": ["https://www.google.com/maps/*", "https://*/*", "http://*/*"],
  "incognito": "split",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scrapify",
    "default_icon": {
      "16": "assets/brand/icon-16.png",
      "32": "assets/brand/icon-32.png",
      "48": "assets/brand/icon-48.png",
      "128": "assets/brand/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
